# ─── GridTrace environment template ─────────────────────────
# Copy to `.env` and fill in real values. Never commit `.env`.

# ─── Database ───────────────────────────────────────────────
# PostgreSQL + pgvector connection string.
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quark

# Storage backend: postgres | sqlite | memory
GRIDTRACE_STORAGE_BACKEND=postgres

# SQLite path (only used when GRIDTRACE_STORAGE_BACKEND=sqlite)
GRIDTRACE_SQLITE_PATH=./data/quark.db

# ─── Quantization & Retrieval ──────────────────────────────
ANCHOR_QUANT_EPSILON=0.02
RAG_ANCHOR_TOP_K=8
RAG_SCORE_THRESHOLD=0.65
RAG_TOP_K=3
RAG_FETCH_K=20

# ─── Embedding ──────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=512
# Optional: local model path overrides HF download
# EMBEDDING_LOCAL_PATH=./models/bge-small-zh-v1.5

# ─── LLM Generator ─────────────────────────────────────────
# Provider: deepseek | openai | ollama | echo
LLM_PROVIDER=echo
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
# Ollama only
LLM_OLLAMA_URL=http://localhost:11434

# ─── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_LOG_LEVEL=info

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
