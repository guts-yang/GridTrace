# GridTrace environment variables (copy to .env and fill in)

# ---- Storage backend ----
# postgres | sqlite | memory
GRIDTRACE_STORAGE_BACKEND=postgres

# PostgreSQL + pgvector (required when backend=postgres)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gridtrace

# SQLite file path (required when backend=sqlite)
SQLITE_PATH=./data/gridtrace.db

# ---- Quantization & retrieval ----
ANCHOR_QUANT_EPSILON=0.02
RAG_ANCHOR_TOP_K=8
RAG_SCORE_THRESHOLD=0.65
RAG_TOP_K=3

# ---- Embedding ----
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ---- LLM generator ----
# echo | deepseek | openai | ollama
LLM_PROVIDER=echo
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
